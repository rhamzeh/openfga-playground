{
  "name": "@openfga/playground-core",
  "version": "0.1.0",
  "description": "Core state management and backend adapter for OpenFGA Playground",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/openfga/playground.git",
    "directory": "packages/core"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@openfga/sdk": "^0.9.6",
    "@openfga/syntax-transformer": "^0.2.1",
    "axios": "^1.16.0",
    "js-yaml": "^4.1.0",
    "nanostores": "^1.3.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.7.0"
  }
}
